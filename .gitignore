# Ignore everything by default
*
*/

# But only track the data and notebooks folders
!.gitignore
!data/
!notebooks/

# Keep directories even if they're empty
!*/

# Ignore common Python files and folders
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
.venv/
venv/
env/
ENV/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Models (if you want to ignore trained models, uncomment below)
# models/*
# !models/.gitkeep

# Logs
*.log
